model Product {
  id        Int     @id @default(autoincrement())
  name String  
  description String? @db.Text
  price Decimal @db.Decimal(10,2)
  stock Int @default(0)
  createAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  productAttributeValues ProductAttributeValue[]

  @@map ("products")
}
